{
  "name": "unlighthouse.dev",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxi prepare && nuxi build",
    "postinstall": "nuxt prepare && simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:docs": "markdownlint ./content && case-police 'content/**/*.md' *.md",
    "lint:docs:fix": "markdownlint ./content --fix && case-police 'content/**/*.md' *.md --fix",
    "typecheck": "nuxt typecheck",
    "twoslash:verify": "nuxt-content-twoslash verify --content-dir content"
  },
  "dependencies": {
    "@nuxtjs/mcp-toolkit": "catalog:",
    "agents": "catalog:",
    "drizzle-orm": "catalog:",
    "nuxt-auth-utils": "catalog:",
    "three": "catalog:",
    "troisjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@iconify-json/carbon": "catalog:",
    "@iconify-json/heroicons": "catalog:",
    "@iconify-json/logos": "catalog:",
    "@iconify-json/material-symbols": "catalog:",
    "@iconify-json/noto": "catalog:",
    "@iconify-json/ph": "catalog:",
    "@iconify-json/radix-icons": "catalog:",
    "@iconify-json/simple-icons": "catalog:",
    "@iconify-json/uil": "catalog:",
    "@iconify-json/unjs": "catalog:",
    "@iconify-json/vscode-icons": "catalog:",
    "@inspira-ui/plugins": "catalog:",
    "@nuxt/content": "catalog:",
    "@nuxt/devtools": "catalog:",
    "@nuxt/fonts": "catalog:",
    "@nuxt/image": "catalog:",
    "@nuxt/scripts": "catalog:",
    "@nuxt/ui": "catalog:",
    "@nuxtjs/seo": "catalog:",
    "@sentry/nuxt": "catalog:",
    "@unovis/vue": "catalog:",
    "@vueuse/core": "catalog:",
    "@vueuse/nuxt": "catalog:",
    "better-sqlite3": "catalog:",
    "case-police": "catalog:",
    "clsx": "catalog:",
    "consola": "catalog:",
    "date-fns": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-harlanzw": "catalog:",
    "lint-staged": "catalog:",
    "markdownlint-cli": "catalog:",
    "motion-v": "catalog:",
    "nitro-cloudflare-dev": "catalog:",
    "nuxt": "catalog:",
    "nuxt-ai-ready": "catalog:",
    "nuxt-build-cache": "catalog:",
    "nuxt-lodash": "catalog:",
    "nuxt-og-image": "catalog:",
    "nuxt-skew-protection": "catalog:",
    "octokit": "catalog:",
    "ofetch": "catalog:",
    "shiki": "catalog:",
    "shiki-transformer-color-highlight": "catalog:",
    "simple-git-hooks": "catalog:",
    "sponsorkit": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tailwindcss-animate": "catalog:",
    "wrangler": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,vue}": [
      "pnpm exec eslint --fix"
    ]
  }
}
